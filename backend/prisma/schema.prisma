// ═══════════════════════════════════════════════════════════
//  MEMS — Medical Equipment Management System
//  Prisma Schema  ·  PostgreSQL
// ═══════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ──────────────────────────────────────────────────

enum Role {
  ADMIN
  SUPERVISOR
  TECHNICIAN
  DEPARTMENT  // department head / nurse who reports faulty devices
  STORE       // storekeeper
}

enum Theme {
  DARK
  LIGHT
}

enum Language {
  EN
  AR
}

enum DeviceStatus {
  OPERATIONAL
  FAULTY
  MAINTENANCE
  DECOMMISSIONED
}

enum WoType {
  REPAIR
  PREVENTIVE_MAINTENANCE
  DECOMMISSION
}

enum WoStatus {
  OPEN             // created, not yet assigned
  IN_PROGRESS
  WAITING_PARTS
  PENDING_APPROVAL // technician marked solved, awaiting supervisor sign-off
  DONE             // supervisor approved / closed
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PMType {
  ROUTINE
  CALIBRATION
  INSPECTION
}

enum PMStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum PMRecurrence {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum PartUnit {
  PCS
  BOX
  SET
  KG
  PAIR
}

enum PartRequestStatus {
  PENDING
  APPROVED
  FULFILLED
  REJECTED
}

enum StoreOrderStatus {
  PENDING   // draft / waiting supplier reply
  ORDERED   // supplier confirmed, shipment en route
  DELIVERED // received by storekeeper — inventory incremented
  REJECTED  // supplier could not fulfil
}

enum FaultUrgency {
  LOW
  MEDIUM
  HIGH
}

enum ReportStatus {
  PENDING     // submitted by department, not yet reviewed
  IN_PROGRESS // WO created and being worked on
  SOLVED      // WO closed, device back in service
  REJECTED    // report dismissed
}

enum EmailStatus {
  SENT
  PENDING
  FAILED
  REPLIED
  ACTION_REQUIRED
}

enum AlertType {
  CRITICAL
  WARNING
  INFO
}

enum RegistrationRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum ReportCategory {
  EQUIPMENT
  MAINTENANCE
  INVENTORY
  FINANCIAL
  COMPLIANCE
}

enum ReportFormat {
  PDF
  EXCEL
  CSV
}

// ─── DEPARTMENT ─────────────────────────────────────────────
// Single source of truth for department names.
// All models reference this table instead of storing raw strings.

model Department {
  id        String   @id @default(cuid())
  name      String   @unique // "ICU" | "ER" | "Surgery" | "Radiology" | …
  code      String   @unique // short code e.g. "ICU", "ER", "RAD"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──────────────────────────────────────────
  users       User[]
  devices     Device[]
  registrationRequests RegistrationRequest[]
}

// ─── USER ───────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  passwordHash      String?
  role              Role      @default(TECHNICIAN)
  initials          String?
  isActive          Boolean   @default(true)
  isSuspended       Boolean   @default(false)
  isActivated       Boolean   @default(false)
  activationToken   String?
  activationExpires DateTime?

  // Per-user UI preferences (persisted to DB so they survive re-login)
  theme    Theme    @default(DARK)
  language Language @default(EN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── FK: Department (optional — not needed for ADMIN) ───
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // ── Relations ──────────────────────────────────────────
  assignedWorkOrders   WorkOrder[] @relation("AssignedTech")
  supervisedWorkOrders WorkOrder[] @relation("SupervisedBy")
  approvedWorkOrders   WorkOrder[] @relation("ApprovedBy")

  assignedPMTasks PMTask[] @relation("AssignedPMTech")
  createdPMTasks  PMTask[] @relation("CreatedByUser")

  partRequests         PartRequest[] @relation("PartRequestUser")
  reviewedPartRequests PartRequest[] @relation("PartRequestReviewer")

  createdStoreOrders  StoreOrder[] @relation("StoreOrderCreator")
  reviewedStoreOrders StoreOrder[] @relation("StoreOrderReviewer")

  submittedFaultReports FaultReport[]

  sentEmailLogs EmailLog[]

  alerts Alert[]

  auditLogs AuditLog[]

  registrationRequest RegistrationRequest?

  requestedReports GeneratedReport[]

  @@index([role])
  @@index([departmentId])
}

// ─── DEVICE ─────────────────────────────────────────────────

model Device {
  id           String       @id @default(cuid())
  assetCode    String       @unique  // human-readable e.g. "DEV-001" — admin-assigned
  name         String
  category     String                // Respiratory | Monitoring | Resuscitation | Pumps | Other
  serialNumber String       @unique
  status       DeviceStatus @default(OPERATIONAL)
  purchaseDate DateTime?
  lastPmDate   DateTime?
  nextPmDate   DateTime?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // ── FK: Department ─────────────────────────────────────
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  // ── Relations ──────────────────────────────────────────
  workOrders   WorkOrder[]
  pmTasks      PMTask[]
  faultReports FaultReport[]

  @@index([departmentId])
  @@index([status])
}

// ─── WORK ORDER ─────────────────────────────────────────────

model WorkOrder {
  id              String   @id @default(cuid())
  workOrderNumber String   @unique  // human-readable e.g. "WO-2024-0001"
  type            WoType
  priority        Priority @default(MEDIUM)
  status          WoStatus @default(OPEN)
  description     String?           // detailed issue description
  notes           String?           // resolution / closure notes
  dueDate         DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // ── FK: Device ─────────────────────────────────────────
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  // ── FK: Assigned technician ────────────────────────────
  assignedToId String?
  assignedTo   User?   @relation("AssignedTech", fields: [assignedToId], references: [id])

  // ── FK: Supervising supervisor ─────────────────────────
  supervisedById String?
  supervisedBy   User?  @relation("SupervisedBy", fields: [supervisedById], references: [id])

  // ── FK: Approving supervisor ───────────────────────────
  approvedById String?
  approvedBy   User?  @relation("ApprovedBy", fields: [approvedById], references: [id])

  // ── FK: Source fault report (nullable — WO may be manual) ──
  faultReportId String?      @unique
  faultReport   FaultReport? @relation(fields: [faultReportId], references: [id])

  // ── FK: Source PM Task (nullable) ──
  pmTaskId String? @unique
  pmTask   PMTask? @relation(fields: [pmTaskId], references: [id])

  // ── Relations ──────────────────────────────────────────
  partRequests PartRequest[]
  auditLogs    AuditLog[]

  @@index([assignedToId])
  @@index([deviceId])
  @@index([status])
  @@index([createdAt])
}

// ─── PREVENTIVE MAINTENANCE TASK ────────────────────────────

model PMTask {
  id             String        @id @default(cuid())
  pmNumber       String        @unique  // human-readable e.g. "PM-2026-0051"
  type           PMType        @default(ROUTINE)
  status         PMStatus      @default(SCHEDULED)
  recurrence     PMRecurrence?
  scheduledAt    DateTime
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // ── FK: Device ─────────────────────────────────────────
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  // ── FK: Assigned technician ────────────────────────────
  assignedToId String?
  assignedTo   User?  @relation("AssignedPMTech", fields: [assignedToId], references: [id])

  // ── FK: Creator (admin / supervisor who scheduled it) ──
  createdById String?
  createdBy   User?  @relation("CreatedByUser", fields: [createdById], references: [id])

  // ── Reverse relation: WO generated from this PM Task ──
  workOrder WorkOrder?

  @@index([scheduledAt])
  @@index([assignedToId])
  @@index([status])
}

// ─── INVENTORY PART ─────────────────────────────────────────

model Part {
  id        String   @id @default(cuid())
  partCode  String   @unique  // human-readable e.g. "PART-1001" / "INV-0001"
  name      String
  category  String            // Cables & Sensors | Filters & Consumables | Batteries & Power | Spare Parts | PPE & Supplies
  unit      PartUnit @default(PCS)
  qty       Int      @default(0)
  minLevel  Int      @default(5)      // low-stock threshold (shown on inventory page)
  location  String?                   // Storeroom | ICU Pharmacy | ER Supplies
  unitPrice Decimal  @default(0) @db.Decimal(10, 2)
  isRecent  Boolean  @default(false)  // flags items on the "Recently Added" tab
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations ──────────────────────────────────────────
  partRequests    PartRequest[]
  storeOrderItems StoreOrderItem[]

  @@index([category])
}

// ─── PART REQUEST ───────────────────────────────────────────
// Technician requests a part from the storeroom for a Work Order.
// Supervisor / admin reviews and approves / rejects.

model PartRequest {
  id            String            @id @default(cuid())
  requestNumber String            @unique  // human-readable e.g. "REQ-1092"
  qty           Int
  status        PartRequestStatus @default(PENDING)
  notes         String?
  createdAt     DateTime          @default(now())
  reviewedAt    DateTime?

  // ── FK: Part ───────────────────────────────────────────
  partId String
  part   Part   @relation(fields: [partId], references: [id])

  // ── FK: Requesting technician ──────────────────────────
  userId String
  user   User   @relation("PartRequestUser", fields: [userId], references: [id])

  // ── FK: Work Order this part is needed for (optional) ──
  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])

  // ── FK: Reviewer (supervisor / admin) ─────────────────
  reviewedById String?
  reviewedBy   User?  @relation("PartRequestReviewer", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([status])
}

// ─── STORE ORDER ────────────────────────────────────────────
// Purchase orders created by the storekeeper to restock parts.
// Admin reviews (approve / reject) before supplier is contacted.

model StoreOrder {
  id              String           @id @default(cuid())
  orderNumber     String           @unique  // human-readable e.g. "PO-9101"
  status          StoreOrderStatus @default(PENDING)
  supplierName    String?
  supplierEmail   String?
  notes           String?
  rejectionReason String?          // populated when admin rejects
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // ── FK: Storekeeper who created it ─────────────────────
  createdById String
  createdBy   User   @relation("StoreOrderCreator", fields: [createdById], references: [id])

  // ── FK: Admin who reviewed it ──────────────────────────
  reviewedById String?
  reviewedBy   User?  @relation("StoreOrderReviewer", fields: [reviewedById], references: [id])

  // ── Relations ──────────────────────────────────────────
  items     StoreOrderItem[]
  emailLogs EmailLog[]

  @@index([createdById])
  @@index([status])
}

// Line items within a Store Order

model StoreOrderItem {
  id        String  @id @default(cuid())
  qty       Int
  unitPrice Decimal @db.Decimal(10, 2)

  orderId String
  order   StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  partId String
  part   Part   @relation(fields: [partId], references: [id])

  @@index([orderId])
}

// ─── FAULT REPORT ───────────────────────────────────────────
// Submitted by the DEPARTMENT role when a device is faulty.
// Admin / supervisor can auto-generate a WO from it.

model FaultReport {
  id          String       @id @default(cuid())
  description String
  urgency     FaultUrgency @default(MEDIUM)
  status      ReportStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // ── FK: Faulty device ──────────────────────────────────
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  // ── FK: Department user who submitted it ───────────────
  submittedById String
  submittedBy   User   @relation(fields: [submittedById], references: [id])

  // ── Reverse relation: WO auto-generated from this report ──
  workOrder WorkOrder?

  @@index([status])
  @@index([submittedById])
  @@index([deviceId])
}

// ─── EMAIL LOG ──────────────────────────────────────────────
// Tracks outbound email communications (store email log page).
// Each thread message is one row; the UI groups by StoreOrder.

model EmailLog {
  id        String      @id @default(cuid())
  subject   String
  body      String
  recipient String                           // supplier email address
  sender    String                           // internal sender display name / email
  status    EmailStatus @default(SENT)
  sentAt    DateTime    @default(now())

  // ── FK: Who sent it (storekeeper) ──────────────────────
  sentById String
  sentBy   User   @relation(fields: [sentById], references: [id])

  // ── FK: Related Store Order ────────────────────────────
  orderId String?
  order   StoreOrder? @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

// ─── ALERT ──────────────────────────────────────────────────
// System-generated notifications shown in admin / supervisor dashboards.
// userId = null + targetRole = broadcast to all users of that role.

model Alert {
  id        String    @id @default(cuid())
  type      AlertType
  title     String
  subtitle  String?
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())          // derive relative time in the API layer

  // Optional contextual links
  workOrderId String?
  deviceId    String?
  partId      String?

  // Targeting: specific user or role broadcast
  targetRole Role?
  userId     String?
  user       User?  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([targetRole])
  @@index([createdAt])
}

// ─── AUDIT LOG ──────────────────────────────────────────────
// Immutable record of all significant state changes.
// Used by the admin Reports page for compliance tracking.

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g. "WO_STATUS_CHANGED" | "PART_STOCKED" | "USER_CREATED"
  entity    String   // model name: "WorkOrder" | "Device" | "Part" | "User" …
  entityId  String   // PK of the changed record
  oldValue  String?  // JSON string of previous state
  newValue  String?  // JSON string of new state
  createdAt DateTime @default(now())

  // ── FK: Who triggered the change ───────────────────────
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // ── FK: Optional WO context ────────────────────────────
  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── REGISTRATION REQUEST ───────────────────────────────────
// Self-registration / access requests shown in admin Users page
// under the "Pending Requests" tab.

model RegistrationRequest {
  id          String                    @id @default(cuid())
  name        String
  email       String                    @unique
  role        Role
  status      RegistrationRequestStatus @default(PENDING)
  submittedAt DateTime                  @default(now())
  reviewedAt  DateTime?

  // ── FK: Department requested (optional) ────────────────
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // ── FK: User created on approval ───────────────────────
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  @@index([status])
}

// ─── GENERATED REPORT ───────────────────────────────────────
// Saved / scheduled report exports shown in the admin Reports page.

model GeneratedReport {
  id          String         @id @default(cuid())
  title       String
  category    ReportCategory
  format      ReportFormat
  sizeBytes   Int?                          // actual byte size — format for display in the API
  period      String?                       // e.g. "Q2 2026", "June 2026"
  generatedAt DateTime       @default(now())

  // ── FK: Who requested the export ───────────────────────
  requestedById String?
  requestedBy   User?   @relation(fields: [requestedById], references: [id])

  @@index([category])
  @@index([requestedById])
}
